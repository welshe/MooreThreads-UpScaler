<Window x:Class="MooreThreadsUpScaler.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Moore Threads UpScaler 1.0"
        Height="500" Width="700"
        MinHeight="500" MinWidth="700"
        ResizeMode="CanMinimize"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="4"
                            Background="{StaticResource AccentBrush}" Margin="0,0,8,0">
                        <TextBlock Text="MT" FontSize="8" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Moore Threads UpScaler 1.0"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding ToggleScalingCommand}"
                        Content="{Binding ScaleButtonLabel}"
                        Margin="0,5,2,5" Padding="32,0"
                        FontSize="12" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="12,9">
                    <TextBlock Text="Game Profiles" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                </Border>
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0" Padding="8,5">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButton}"
                                Padding="7,3" FontSize="15" Content="+"
                                Command="{Binding AddProfileCommand}"
                                ToolTip="Add new profile"/>
                        <Button Style="{StaticResource GhostButton}"
                                Padding="7,3" FontSize="14" Content="✕"
                                Margin="4,0,0,0"
                                Command="{Binding DeleteProfileCommand}"
                                ToolTip="Delete selected profile"/>
                    </StackPanel>
                </Border>
                <ListBox x:Name="ProfileListBox" ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="ProfileListBox_MouseDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="itemBd"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource AccentBrush}"
                                                BorderThickness="0"
                                                Padding="10,8">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="itemBd" Property="BorderThickness" Value="3,0,0,0"/>
                                                <Setter TargetName="itemBd" Property="Background" Value="{StaticResource CardBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="itemBd" Property="Background" Value="{StaticResource Card2Brush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                       Foreground="{StaticResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- RIGHT — settings -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="16,14,16,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: Target + Frame Generation -->
                <StackPanel Grid.Column="0">

                    <TextBlock Text="Target Game" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding AvailableWindows}"
                                          SelectedItem="{Binding SelectedWindow}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                        Command="{Binding RefreshWindowsCommand}"
                                        Content="↺" FontSize="13"
                                        Padding="6,4" Margin="5,0,0,0" ToolTip="Refresh"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Frame Generation" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Enable" Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding FrameGenEnabled}"
                                          Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Off"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FrameGenEnabled}" Value="True">
                                                        <Setter Property="Text" Value="On"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </CheckBox>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Multiplier" Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                                <ComboBox Grid.Column="1"
                                          SelectedIndex="{Binding FrameGenMultiplier, Converter={StaticResource MultiplierToIndex}}"
                                          IsEnabled="{Binding FrameGenEnabled}">
                                    <ComboBoxItem Content="X2"/>
                                    <ComboBoxItem Content="X3"/>
                                    <ComboBoxItem Content="X4"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- RIGHT COLUMN: Upscaler + GPU -->
                <StackPanel Grid.Column="2">

                    <TextBlock Text="Upscaler" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Algorithm" Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding Upscalers}"
                                          SelectedItem="{Binding SelectedUpscaler}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="GPU" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Active GPU" Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                                <TextBlock Grid.Column="1" Text="{Binding GpuLabel}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="VRAM" Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                                <TextBlock Grid.Column="1" Text="{Binding GpuVramLabel}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- BOTTOM STATUS BAR -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="7" Height="7"
                         VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource TextMuted}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInjected}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           FontSize="11" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
